FAL_KEY=replace_with_your_fal_key
OPENAI_API_KEY=replace_with_your_openai_api_key_if_required_by_the_fal_model
PORT=8765
PUBLIC_BASE_URL=http://127.0.0.1:8765

# Optional: set this to a Google Drive Desktop synced folder.
# Example: /Users/yourname/Library/CloudStorage/GoogleDrive-your@email.com/My Drive/GO Mall AI Outputs
# If this folder contains subfolders named by SKU, approved files are copied
# into the matching SKU subfolder when the frontend SKU field is filled.
DRIVE_OUTPUT_DIR=

# Optional: upload approved images directly to Google Drive API.
# Recommended for My Drive folders: OAuth. The server uploads as your Google account,
# searches direct child folders by SKU, and uploads into the matching folder.
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/api/google/oauth/callback
GOOGLE_DRIVE_TOKEN_PATH=.oauth/google-token.json

# Legacy service account mode. Use only with Shared Drives or delegated OAuth,
# because service accounts do not have normal My Drive storage quota.
# GOOGLE_DRIVE_AUTH_MODE=service-account
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Alternative to GOOGLE_APPLICATION_CREDENTIALS:
# GOOGLE_DRIVE_CREDENTIALS_JSON={"type":"service_account",...}
# If true, create a new SKU folder under the root folder when no match is found.
GOOGLE_DRIVE_CREATE_SKU_FOLDER=false
# If false, delete the local approved image after successful Drive sync/API upload.
KEEP_LOCAL_APPROVED=false

# Production phase placeholders.
# Use a hosted Postgres/Supabase URL when moving beyond local history.
DATABASE_URL=
# Use S3/R2/GCS for shared uploads and approved outputs.
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
