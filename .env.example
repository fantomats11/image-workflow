# Image Workflow environment template
#
# Put real keys/secrets in `.env`. Keep this file safe to commit.
# Recommended pilot defaults are dry-run first: no WordPress publish and no live generation until explicitly enabled.


# -----------------------------------------------------------------------------
# App runtime
# -----------------------------------------------------------------------------
PORT=8765
PUBLIC_BASE_URL=http://127.0.0.1:8765
APP_TIMEZONE=Asia/Bangkok


# -----------------------------------------------------------------------------
# Supabase production OS
# Required when running the web app/server against the production workflow DB.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------------------
# AI image generation
# FAL_KEY is required for real generation. OPENAI_API_KEY is not required for
# the current FAL gpt-image-2/edit workflow.
# -----------------------------------------------------------------------------
FAL_KEY=
OPENAI_API_KEY=
AI_IMAGE_MODEL=openai/gpt-image-2/edit
AI_GENERATION_DRY_RUN=true
AI_GENERATION_DEFAULT_QUALITY=low
AI_GENERATION_ESTIMATED_COST_PER_GENERATION=0.04


# -----------------------------------------------------------------------------
# Local/Google Drive exports
# GOOGLE_DRIVE_ROOT_FOLDER_ID is the parent folder containing SKU-named folders.
# Use OAuth for normal My Drive folders.
# -----------------------------------------------------------------------------
DRIVE_OUTPUT_DIR=
GOOGLE_DRIVE_ROOT_FOLDER_ID=
GOOGLE_DRIVE_AUTH_MODE=oauth
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8765/api/google/oauth/callback
GOOGLE_DRIVE_TOKEN_PATH=.oauth/google-token.json
GOOGLE_DRIVE_CREATE_SKU_FOLDER=false
KEEP_LOCAL_APPROVED=false

# Legacy/service-account mode. Use only for Shared Drives or delegated OAuth.
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_DRIVE_CREDENTIALS_JSON=


# -----------------------------------------------------------------------------
# WooCommerce / WordPress
# Keep WORDPRESS_DRY_RUN=true until the pilot is approved.
# For this project, 1 SKU = 1 product. No variation SKU scan is needed.
# -----------------------------------------------------------------------------
WORDPRESS_DRY_RUN=true

RAC_WP_SITE_URL=https://www.rentacoat.com
RAC_WOO_CONSUMER_KEY=
RAC_WOO_CONSUMER_SECRET=
RAC_WP_USERNAME=
RAC_WP_APP_PASSWORD=

GOMALL_WP_SITE_URL=https://gomall.fashion
GOMALL_WOO_CONSUMER_KEY=
GOMALL_WOO_CONSUMER_SECRET=
GOMALL_WP_USERNAME=
GOMALL_WP_APP_PASSWORD=


# -----------------------------------------------------------------------------
# LINE approval surface
# LINE_TARGET_USER_ID must belong to the same Messaging API channel as the token.
# -----------------------------------------------------------------------------
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_TARGET_USER_ID=
PILOT_BATCH_SIZE=10


# -----------------------------------------------------------------------------
# Automation worker
# Use AUTOMATION_EMBEDDED_WORKER=true for the no-extra-service dry-run pilot.
# A dedicated Render worker service can later run `npm run worker`.
# Keep dry-run true until generation and WordPress publish are approved.
# -----------------------------------------------------------------------------
AUTOMATION_EMBEDDED_WORKER=false
AUTOMATION_WORKER_ID=
AUTOMATION_WORKER_POLL_INTERVAL_MS=5000


# -----------------------------------------------------------------------------
# Optional future storage
# Keep empty until approved outputs move to external object storage.
# -----------------------------------------------------------------------------
DATABASE_URL=
OBJECT_STORAGE_BUCKET=
OBJECT_STORAGE_REGION=
